# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD for Docker deployments.
MINIO_ACCESS_KEY=hunterminio
MINIO_SECRET_KEY=HunterMinio2026Secure
MINIO_BUCKET=hunter-reports
MINIO_ROOT_USER=hunterminio
MINIO_ROOT_PASSWORD=HunterMinio2026Secure
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0
ELASTICSEARCH_URL=http://elasticsearch:9200
MISP_URL=https://misp
MISP_KEY=change_me_misp_api_key
MISP_ADMIN_EMAIL=admin@example.local
MISP_ADMIN_PASSWORD=change_me_misp_admin_password
MISP_ADMIN_PASSPHRASE=change_me_misp_admin_passphrase
