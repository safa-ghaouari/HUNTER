POSTGRES_DB=hunter
POSTGRES_USER=hunter
POSTGRES_PASSWORD=change_me_postgres_password
DATABASE_URL=postgresql+asyncpg://hunter:change_me_postgres_password@postgres:5432/hunter
SECRET_KEY=change_me_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=60
BOOTSTRAP_ADMIN_EMAIL=soc.admin@example.local
BOOTSTRAP_ADMIN_PASSWORD=change_me_admin_password
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=change_me_vault_token
VAULT_DEV_ROOT_TOKEN_ID=change_me_vault_root_token
MINIO_ENDPOINT=minio:9000
# Unless you create a separate MinIO user, keep these aligned with
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD for Docker deployments.
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key
MINIO_BUCKET=hunter-reports
MINIO_ROOT_USER=change_me_minio_root_user
MINIO_ROOT_PASSWORD=change_me_minio_root_password
REDIS_URL=redis://redis:6379/0
ELASTICSEARCH_URL=http://elasticsearch:9200
MISP_URL=https://misp
MISP_KEY=change_me_misp_api_key
MISP_ADMIN_EMAIL=admin@example.local
MISP_ADMIN_PASSWORD=change_me_misp_admin_password
MISP_ADMIN_PASSPHRASE=change_me_misp_admin_passphrase
# Replace localhost with your VM IP or DNS name before remote deployment.
MISP_BASE_URL=https://localhost:8443
MISP_DB_NAME=misp
MISP_DB_USER=misp
MISP_DB_PASSWORD=change_me_misp_db_password
MISP_DB_ROOT_PASSWORD=change_me_misp_db_root_password
OPENCTI_URL=http://opencti:8080
OPENCTI_TOKEN=change_me_opencti_token
OPENCTI_ADMIN_EMAIL=admin@example.local
OPENCTI_ADMIN_PASSWORD=change_me_opencti_admin_password
# OpenCTI expects a UUID-formatted admin token on first boot.
OPENCTI_ADMIN_TOKEN=change_me_opencti_admin_token
# Replace localhost with your VM IP or DNS name before remote deployment.
OPENCTI_BASE_URL=http://localhost:8080
OPENCTI_HEALTH_ACCESS_KEY=change_me_opencti_health_key
OPENCTI_ENCRYPTION_KEY=change_me_opencti_encryption_key
THEHIVE_URL=http://thehive:9000
THEHIVE_API_KEY=change_me_thehive_api_key
TH_SECRET=change_me_thehive_secret
RABBITMQ_DEFAULT_USER=huntermq
RABBITMQ_DEFAULT_PASSWORD=change_me_rabbitmq_password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
REACT_APP_API_URL=/api
HUNTER_TLS_CERT_CN=localhost
OLLAMA_URL=http://ollama:11434

# Optional Phase 2 bootstrap inputs for threat-intelligence sources.
# Source URLs themselves are stored as Source records in the database, not read
# directly from .env by the collectors.
COLLECTION_SCHEDULER_INTERVAL_SECONDS=60
OTX_API_KEY=
ABUSE_CH_URL=https://urlhaus-api.abuse.ch/v1/urls/recent/
CIRCL_FEED_URL=https://www.circl.lu/doc/misp/feed-osint/manifest.json
