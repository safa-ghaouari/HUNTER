THEHIVE_API_KEY=
THEHIVE_ADMIN_LOGIN=admin@thehive.local
THEHIVE_ADMIN_PASSWORD=secret
THEHIVE_ORGANISATION=
TH_SECRET=change_me_thehive_secret
RABBITMQ_DEFAULT_USER=huntermq
RABBITMQ_DEFAULT_PASSWORD=change_me_rabbitmq_password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
REACT_APP_API_URL=/api
HUNTER_TLS_CERT_CN=localhost
# Logstash HTTP push endpoint basic-auth (port 8088)
LOGSTASH_HTTP_USER=logstash
LOGSTASH_HTTP_PASSWORD=change_me_logstash_password
