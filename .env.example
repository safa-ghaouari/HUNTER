POSTGRES_DB=hunter
POSTGRES_USER=hunter
POSTGRES_PASSWORD=change_me_postgres_password
DATABASE_URL=postgresql+asyncpg://hunter:change_me_postgres_password@postgres:5432/hunter
SECRET_KEY=hunter-local-dev-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
BOOTSTRAP_ADMIN_EMAIL=soc.admin@hunter.local
BOOTSTRAP_ADMIN_PASSWORD=HunterAdmin2026Secure
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=hunter-vault-root-token-2026
VAULT_DEV_ROOT_TOKEN_ID=hunter-vault-root-token-2026
MINIO_ENDPOINT=minio:9000
