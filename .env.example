# Optional Phase 2 bootstrap inputs for threat-intelligence sources.
# Source URLs themselves are stored as Source records in the database, not read
# directly from .env by the collectors.
COLLECTION_SCHEDULER_INTERVAL_SECONDS=60
OTX_API_KEY=
ABUSE_CH_AUTH_KEY=
ABUSE_CH_URL=https://urlhaus-api.abuse.ch/v2/files/exports/{auth_key}/recent.csv
CIRCL_FEED_URL=https://www.circl.lu/doc/misp/feed-osint/manifest.json
