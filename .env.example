MISP_BASE_URL=https://localhost:8443
MISP_DB_NAME=misp
MISP_DB_USER=misp
MISP_DB_PASSWORD=change_me_misp_db_password
MISP_DB_ROOT_PASSWORD=change_me_misp_db_root_password
OPENCTI_URL=http://opencti:8080
OPENCTI_TOKEN=00000000-0000-4000-8000-000000000001
OPENCTI_ADMIN_EMAIL=admin@example.local
OPENCTI_ADMIN_PASSWORD=change_me_opencti_admin_password
# OpenCTI expects a UUID-formatted admin token on first boot.
OPENCTI_ADMIN_TOKEN=00000000-0000-4000-8000-000000000001
# Replace localhost with your VM IP or DNS name before remote deployment.
OPENCTI_BASE_URL=http://localhost:8080
OPENCTI_HEALTH_ACCESS_KEY=change_me_opencti_health_key
OPENCTI_ENCRYPTION_KEY=hunter-opencti-encryption-key-2026
